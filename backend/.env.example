APP_ENV=development
APP_NAME=RAG智能文档检索助手
API_PREFIX=/api

DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5433/rag_assistant
REDIS_URL=redis://127.0.0.1:6379/0

DASHSCOPE_API_KEY=
LLM_PROVIDER=dashscope
# production 环境不得使用 acceptance 模式
LLM_MODE=production
LLM_BASE_URL=
QWEN_CHAT_MODEL=qwen-plus
QWEN_VL_MODEL=qwen-vl-max-latest
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v1
RERANKER_MODEL=gte-rerank-v2
SEARCH_PROVIDER=brave
SEARCH_API_KEY=
SEARCH_BASE_URL=
SEARCH_TIMEOUT_SECONDS=8
MULTIMODAL_ENABLED=true
MAX_VISUAL_ASSETS_PER_DOCUMENT=8
VISUAL_CAPTION_TIMEOUT_SECONDS=12
# Neo4j 为可选依赖；未配置时 GraphRAG 走降级路径
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
GRAPH_QUERY_LIMIT=5

FILE_STORAGE_PATH=./data/uploads
MAX_UPLOAD_SIZE_MB=50

CHUNK_SIZE=800
CHUNK_OVERLAP=150
VECTOR_TOP_K=12
RERANK_TOP_N=5

